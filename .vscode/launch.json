{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Backend",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/backend/cmd/daedalus/main.go",
            "cwd": "${workspaceFolder}/bin",
            "env": {
                "PORT": "8080"
            },
            "args": []
        },
        {
            "name": "Attach to Backend (Delve)",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "port": 40000,
            "host": "127.0.0.1",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Debug Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**",
                "<node_internals>/internal/**"
            ],
            "smartStep": true,
            "runtimeArgs": ["--disable-web-security"]
        },
        {
            "name": "Debug Frontend (ChromeHeadless)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "sourceMaps": true,
            "smartStep": true,
            "runtimeArgs": [
                "--headless=new",
                "--no-sandbox",
                "--disable-setuid-sandbox",
                "--disable-web-security"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Debug All (Backend + Frontend)",
            "configurations": [
                "Attach to Backend (Delve)",
                "Debug Frontend (ChromeHeadless)"
            ],
            "preLaunchTask": "Dev (Debug Mode)",
            "presentation": {
                "hidden": false,
                "order": 1,
                "group": "1_debug"
            }
        }
    ]
}
